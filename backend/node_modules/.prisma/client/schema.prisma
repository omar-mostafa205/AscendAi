generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @db.Uuid
  email             String   @unique
  name              String?
  avatarUrl         String?  @map("avatar_url")
  subscriptionTier  String   @default("free") @map("subscription_tier")
  sessionsRemaining Int      @default(5) @map("sessions_remaining")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  jobs              Job[]
  interviewSessions InterviewSession[]

  @@map("profiles")
}

model Job {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  title          String
  company        String
  jobDescription String   @map("job_description") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  personas          Persona[]
  interviewSessions InterviewSession[]

  @@index([userId])
  @@map("jobs")
}

model Persona {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId                  String   @map("job_id") @db.Uuid
  type                   String // "technical" | "behavioral" | "system_design"
  name                   String
  role                   String
  company                String?
  background             String?  @db.Text
  interviewStyle         String   @map("interview_style")
  openessLevel           String   @map("openess_level")
  conscientiousnessLevel String   @map("conscientiousness_level")
  extraversionLevel      String   @map("extraversion_level")
  agreeablenessLevel     String   @map("agreeableness_level")
  neuroticismLevel       String   @map("neuroticism_level")
  createdAt              DateTime @default(now()) @map("created_at")

  job               Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[]

  @@unique([jobId, type])
  @@index([jobId])
  @@map("personas")
}

model InterviewSession {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  jobId           String?   @map("job_id") @db.Uuid
  personaId       String?   @map("persona_id") @db.Uuid
  voiceId         String?   @map("voice_id")
  scenarioType    String    @map("scenario_type")
  difficultyLevel String    @default("medium") @map("difficulty_level")
  status          String    @default("active")
  livekitRoomName String?   @unique @map("livekit_room_name")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")
  overallScore    Int?      @map("overall_score")
  feedback        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  persona  Persona?           @relation(fields: [personaId], references: [id], onDelete: SetNull)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  job      Job?               @relation(fields: [jobId], references: [id], onDelete: SetNull)
  messages InterviewMessage[]

  @@index([userId])
  @@index([jobId])
  @@index([personaId])
  @@index([status])
  @@map("interview_sessions")
}

model InterviewMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("interview_messages")
}
